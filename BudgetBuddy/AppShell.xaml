<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BudgetBuddy.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BudgetBuddy.Views"
    FlyoutBehavior="Disabled"
    Title="BudgetBuddy">

    <TabBar>
        <ShellContent Title="Dashboard"
                      ContentTemplate="{DataTemplate views:MainPage}"
                      Route="MainPage" />
        <ShellContent Title="Budget"
                      ContentTemplate="{DataTemplate views:BudgetPage}"
                      Route="BudgetPage" />
        <ShellContent Title="Savings"
                      ContentTemplate="{DataTemplate views:SavingsPage}"
                      Route="SavingsPage" />
    </TabBar>

</Shell>
