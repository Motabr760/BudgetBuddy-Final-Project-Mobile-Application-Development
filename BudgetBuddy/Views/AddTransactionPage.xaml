<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetBuddy.Views.AddTransactionPage"
             Title="{Binding PageTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="{Binding PageTitle}" FontSize="24" FontAttributes="Bold"/>

            <VerticalStackLayout Spacing="6">
                <Label Text="Title" FontSize="12"/>
                <Entry Placeholder="e.g. Groceries" Text="{Binding Title}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Amount" FontSize="12"/>
                <Entry Placeholder="0.00" Keyboard="Numeric" Text="{Binding Amount}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Category" FontSize="12"/>
                <Picker Title="Select a category"
                        ItemsSource="{Binding Categories}"
                        SelectedItem="{Binding SelectedCategory}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Date" FontSize="12"/>
                <DatePicker Date="{Binding Date}"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                <Label Grid.Column="0" Text="This is income" VerticalOptions="Center"/>
                <Switch Grid.Column="1" IsToggled="{Binding IsIncome}"/>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="Cancel"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                        Command="{Binding CancelCommand}"/>
                <Button Grid.Column="1"
                        Text="Save"
                        Command="{Binding SaveTransactionCommand}"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
